"use client"

import { useMemo, useRef, useState } from "react"

type Song = {
  id: number
  artist: string
  title: string
  producer: string
  genre: string
  playlist: string
  cover: string
  audio?: string
  verified?: boolean
  likes: number
  comments: string[]
  views: number
  duration?: number
}

export default function Page() {
  const audioRef = useRef<HTMLAudioElement | null>(null)

  const [songs, setSongs] = useState<Song[]>([])
  const [search, setSearch] = useState("")
  const [playing, setPlaying] = useState<Song | null>(null)
  const [queue, setQueue] = useState<Song[]>([])
  const [recording, setRecording] = useState(false)
  const [mediaRecorder, setMediaRecorder] = useState<any>(null)
  const [progress, setProgress] = useState(0)
  const [currentTime, setCurrentTime] = useState("0:00")
  const [durationText, setDurationText] = useState("0:00")
  const [showUpload, setShowUpload] = useState(false)
  const [theme, setTheme] = useState("dark")
  const [fullVideo, setFullVideo] = useState(false)

  const [artist, setArtist] = useState("")
  const [title, setTitle] = useState("")
  const [producer, setProducer] = useState("")
  const [genre, setGenre] = useState("")
  const [playlist, setPlaylist] = useState("")
  const [cover, setCover] = useState("")

  const filteredSongs = useMemo(() => {
    return songs.filter((song) =>
      `${song.artist} ${song.title} ${song.genre}`
        .toLowerCase()
        .includes(search.toLowerCase())
    )
  }, [songs, search])

  function formatTime(time: number) {
    if (!time || Number.isNaN(time)) return "0:00"

    const min = Math.floor(time / 60)
    const sec = Math.floor(time % 60)
      .toString()
      .padStart(2, "0")

    return `${min}:${sec}`
  }

  function uploadSong(
    e: React.ChangeEvent<HTMLInputElement>
  ) {
    const file = e.target.files?.[0]

    if (!file) return

    const url = URL.createObjectURL(file)

    const newSong: Song = {
      id: Date.now(),
      artist: artist || "Unknown Artist",
      title: title || file.name,
      producer,
      genre,
      playlist,
      cover:
        cover ||
        "https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?q=80&w=1600&auto=format&fit=crop",
      audio: url,
      verified: false,
      likes: 0,
      comments: [],
      views: 0,
    }

    setSongs((prev) => [newSong, ...prev])

    setArtist("")
    setTitle("")
    setProducer("")
    setGenre("")
    setPlaylist("")
    setCover("")
  }

  function playSong(song: Song) {
    if (!song.audio || !audioRef.current) return

    audioRef.current.src = song.audio
    audioRef.current.play()

    setPlaying(song)

    setSongs((prev) =>
      prev.map((s) =>
        s.id === song.id
          ? { ...s, views: s.views + 1 }
          : s
      )
    )
  }

  function pauseSong() {
    audioRef.current?.pause()
  }

  function likeSong(id: number) {
    setSongs((prev) =>
      prev.map((song) =>
        song.id === id
          ? { ...song, likes: song.likes + 1 }
          : song
      )
    )
  }

  function addToQueue(song: Song) {
    setQueue((prev) => [...prev, song])
  }

  function deleteSong(id: number) {
    setSongs((prev) =>
      prev.filter((song) => song.id !== id)
    )
  }

  const totalLikes = songs.reduce(
    (a, b) => a + b.likes,
    0
  )

  const appStyle = {
    display: "flex",
    minHeight: "100vh",
    background:
      theme === "dark"
        ? "linear-gradient(135deg,#00154d,#00cfff)"
        : "linear-gradient(135deg,#f4f7ff,#d9ffff)",
    color: theme === "dark" ? "white" : "black",
    fontFamily: "Arial",
  } as const

  return (
    <div style={appStyle}>
      <div
        style={{
          width: 220,
          background:
            theme === "dark" ? "#00091f" : "#dffcff",
          padding: 20,
          borderRight: "2px solid #00d9ff",
        }}
      >
        <h1 style={{ fontSize: 52 }}>
          Z Music
          <br />
          V19
        </h1>

        <button style={sideButton}>
          🎟️ Free + Ads
        </button>

        <div style={{ lineHeight: 2 }}>
          <div>🎵 Tracks: {songs.length}</div>
          <div>❤️ Likes: {totalLikes}</div>
          <div>🎧 Queue: {queue.length}</div>
        </div>

        <h2 style={{ marginTop: 40 }}>
          Sections
        </h2>

        <button
          style={sideButton}
          onClick={() =>
            setShowUpload(!showUpload)
          }
        >
          Real Upload
        </button>

        <button
          style={sideButton}
          onClick={() =>
            setTheme(
              theme === "dark"
                ? "light"
                : "dark"
            )
          }
        >
          Toggle Theme
        </button>

        <button
          style={sideButton}
          onClick={() =>
            setFullVideo(!fullVideo)
          }
        >
          Full Video
        </button>
      </div>

      <div style={{ flex: 1, padding: "30px 30px 90px" }}>
        <div
          style={{
            background:
              "linear-gradient(90deg,#ffe600,#ff9d5c,#ff5cb8)",
            padding: "18px",
            borderRadius: 20,
            color: "black",
            fontWeight: "bold",
            marginBottom: 20,
          }}
        >
          SPONSOR AD — V19 Creator Platform
        </div>

        <h1 style={{ fontSize: 64 }}>
          Music Business Platform V19
        </h1>

        <input
          value={search}
          onChange={(e) =>
            setSearch(e.target.value)
          }
          placeholder="Search music..."
          style={searchStyle}
        />

        {showUpload && (
          <div style={uploadBox}>
            <h2>Upload MP3</h2>

            <input
              value={artist}
              onChange={(e) =>
                setArtist(e.target.value)
              }
              placeholder="Artist"
              style={inputStyle}
            />

            <input
              value={title}
              onChange={(e) =>
                setTitle(e.target.value)
              }
              placeholder="Song Title"
              style={inputStyle}
            />

            <input
              value={producer}
              onChange={(e) =>
                setProducer(e.target.value)
              }
              placeholder="Producer"
              style={inputStyle}
            />

            <input
              value={genre}
              onChange={(e) =>
                setGenre(e.target.value)
              }
              placeholder="Genre"
              style={inputStyle}
            />

            <input
              value={playlist}
              onChange={(e) =>
                setPlaylist(e.target.value)
              }
              placeholder="Playlist"
              style={inputStyle}
            />

            <input
              value={cover}
              onChange={(e) =>
                setCover(e.target.value)
              }
              placeholder="Cover URL"
              style={inputStyle}
            />

            <input
              type="file"
              accept="audio/*"
              onChange={uploadSong}
              style={{ marginTop: 20 }}
            />
          </div>
        )}

        <div
          style={{
            display: "grid",
            gridTemplateColumns:
              "repeat(auto-fit,minmax(420px,1fr))",
            gap: 24,
            marginTop: 30,
          }}
        >
          {filteredSongs.map((song) => (
            <div
              key={song.id}
              style={{
                background:
                  "rgba(0,0,40,.7)",
                border:
                  "2px solid #00d9ff",
                borderRadius: 24,
                overflow: "hidden",
              }}
            >
              <img
                src={song.cover}
                style={{
                  width: "100%",
                  height: 280,
                  objectFit: "cover",
                }}
              />

              <div style={{ padding: 24 }}>
                <h2 style={{ fontSize: 42 }}>
                  {song.artist}
                </h2>

                <h3>{song.title}</h3>

                <div style={{ lineHeight: 2 }}>
                  <div>
                    Producer: {song.producer}
                  </div>
                  <div>
                    Genre: {song.genre}
                  </div>
                  <div>
                    Playlist: {song.playlist}
                  </div>
                  <div>
                    Views: {song.views}
                  </div>
                  <div>
                    Likes: {song.likes}
                  </div>
                </div>

                <div
                  style={{
                    display: "flex",
                    gap: 12,
                    flexWrap: "wrap",
                    marginTop: 20,
                  }}
                >
                  <button
                    style={playBtn}
                    onClick={() =>
                      playSong(song)
                    }
                  >
                    Play
                  </button>

                  <button
                    style={queueBtn}
                    onClick={() =>
                      pauseSong()
                    }
                  >
                    Pause
                  </button>

                  <button
                    style={greenBtn}
                    onClick={() =>
                      addToQueue(song)
                    }
                  >
                    Queue
                  </button>

                  <button
                    style={yellowBtn}
                    onClick={() =>
                      likeSong(song.id)
                    }
                  >
                    Like
                  </button>

                  <button
                    style={redBtn}
                    onClick={() =>
                      deleteSong(song.id)
                    }
                  >
                    Delete
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div
        style={{
          position: "fixed",
          left: 220,
          right: 0,
          bottom: 0,
          height: 64,
          background:
            "rgba(0,0,40,.95)",
          borderTop:
            "2px solid #00d9ff",
          padding: "10px 18px",
minHeight: 70,
          display: "flex",
          alignItems: "center",
          gap: 20,
          zIndex: 40,
        }}
      >
        <div>
          <div
            style={{
              fontWeight: "bold",
            }}
          >
            Now Playing
          </div>

          <div>
            {playing
              ? `${playing.artist} - ${playing.title}`
              : "No media playing"}
          </div>
        </div>

        <button
          style={playBtn}
          onClick={() =>
            audioRef.current?.play()
          }
        >
          Play
        </button>

        <button
          style={greenBtn}
          onClick={() =>
            audioRef.current?.pause()
          }
        >
          Pause
        </button>

        <div
          style={{
            width: 240,
            height: 12,
            background:
              "rgba(255,255,255,.2)",
            borderRadius: 999,
            overflow: "hidden",
          }}
        >
          <div
            style={{
              width: `${progress}%`,
              height: "100%",
              background:
                "linear-gradient(90deg,#00d9ff,#ffe600)",
            }}
          />
        </div>

        <div>
          {currentTime} / {durationText}
        </div>
      </div>

      {fullVideo && playing && (
        <div
          onClick={() =>
            setFullVideo(false)
          }
          style={{
            position: "fixed",
            inset: 0,
            background:
              "rgba(0,0,0,.95)",
            zIndex: 999,
            display: "flex",
            flexDirection: "column",
            alignItems: "center",
            justifyContent: "center",
            padding: 40,
          }}
        >
          <img
            src={playing.cover}
            style={{
              width: "70vw",
              maxHeight: "70vh",
              objectFit: "cover",
              borderRadius: 30,
              boxShadow:
                "0 0 40px #00d9ff",
            }}
          />

          <h1 style={{ fontSize: 64 }}>
            {playing.artist}
          </h1>

          <h2>{playing.title}</h2>
        </div>
      )}

      <audio
        ref={audioRef}
        onTimeUpdate={() => {
          if (!audioRef.current) return

          const current =
            audioRef.current.currentTime

          const duration =
            audioRef.current.duration

          setCurrentTime(
            formatTime(current)
          )

          setDurationText(
            formatTime(duration)
          )

          setProgress(
            (current / duration) * 100 || 0
          )
        }}
      />
    </div>
  )
}

const sideButton = {
  width: "100%",
  padding: 14,
  borderRadius: 12,
  border: "none",
  marginBottom: 12,
  background: "#97f3f3",
  fontWeight: "bold",
  cursor: "pointer",
}

const searchStyle = {
  width: "100%",
  padding: 18,
  borderRadius: 18,
  border: "2px solid #00d9ff",
  background: "#001040",
  color: "white",
  marginTop: 20,
  fontSize: 18,
}

const uploadBox = {
  marginTop: 30,
  padding: 30,
  borderRadius: 30,
  border: "3px dashed #00d9ff",
  background: "rgba(0,0,0,.3)",
}

const inputStyle = {
  width: "100%",
  padding: 16,
  marginBottom: 16,
  borderRadius: 14,
  border: "2px solid #00d9ff",
  background: "#001040",
  color: "white",
  fontSize: 16,
}

const playBtn = {
  border: "none",
  borderRadius: 10,
  padding: "10px 14px",
  background: "#00d9ff",
  fontWeight: "bold",
  cursor: "pointer",
}

const queueBtn = {
  border: "none",
  borderRadius: 10,
  padding: "10px 14px",
  background: "white",
  fontWeight: "bold",
  cursor: "pointer",
}

const greenBtn = {
  border: "none",
  borderRadius: 10,
  padding: "10px 14px",
  background: "#90ee90",
  fontWeight: "bold",
  cursor: "pointer",
}

const yellowBtn = {
  border: "none",
  borderRadius: 10,
  padding: "10px 14px",
  background: "#ffe600",
  fontWeight: "bold",
  cursor: "pointer",
}

const redBtn = {
  border: "none",
  borderRadius: 10,
  padding: "10px 14px",
  background: "#ff74b1",
  fontWeight: "bold",
  cursor: "pointer",
}
